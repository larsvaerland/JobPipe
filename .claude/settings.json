{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(pnpm test *)",
      "Bash(npm test *)",
      "Bash(pytest *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker *"
    ],
    "filesystem": {
      "allowRead": [
        "."
      ],
      "denyRead": [
        "~/.aws/credentials"
      ]
    }
  },
  "env": {
    "PROJECT_PLAYBOOK": "docs/ai-playbook.md",
    "PROJECT_VISION": "docs/vision.md"
  }
}