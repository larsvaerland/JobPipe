{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git checkout *)",
      "Bash(git worktree *)",
      "Bash(gh pr *)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "./tmp",
        "./build"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org"
      ]
    }
  }
}