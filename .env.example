OPENAI_API_KEY=sk-...your-key-here...

JOBPIPE_CSV_URL=https://docs.google.com/spreadsheets/d/e/...your-published-csv-url...

# Optional: move personal data out of the repo while keeping code and generated
# dashboard artifacts in the repo. If set, JobPipe will look here for:
# - profile_pack.md
# - resume.json
# - application_state.json
# - gmail_credentials.json / gmail_token.json
# - suggested_jobs.jsonl
# - profile_embedding.npy
#
# Examples below use Windows paths; POSIX paths work the same way.
#
# Example:
# JOBPIPE_DATA_DIR=C:\Users\yourname\JobpipeData
#
# Optional finer-grained overrides if you want JobPipe's future runtime layout
# split into dedicated folders:
# JOBPIPE_DB_DIR=C:\Users\yourname\JobpipeData\db
# JOBPIPE_DB_PATH=C:\Users\yourname\JobpipeData\db\jobpipe.sqlite
# JOBPIPE_ARTIFACT_DIR=C:\Users\yourname\JobpipeData\artifacts
# JOBPIPE_DOCUMENTS_DIR=C:\Users\yourname\JobpipeData\documents
# JOBPIPE_EXPORT_DIR=C:\Users\yourname\JobpipeData\exports
# JOBPIPE_JOBS_STATE_PATH=C:\Users\yourname\JobpipeData\jobs_state.json
# JOBPIPE_JOBS_DELTA_PATH=C:\Users\yourname\JobpipeData\jobs_delta.jsonl
# JOBPIPE_JOBS_EXPIRED_PATH=C:\Users\yourname\JobpipeData\jobs_expired.jsonl
# JOBPIPE_CANDIDATE_ID=default

NAV_API_ENABLED=true
NAV_BASE_URL=https://pam-stilling-feed.nav.no
NAV_TOKEN_PATH=/api/publicToken
NAV_FEED_PATH=/api/v1/feed
NAV_FETCH_RETRIES=5
NAV_FETCH_BACKOFF_SECONDS=0.7
NAV_MAX_NEW_PER_RUN=50
NAV_DESC_CHAR_LIMIT=5000
NAV_TOKEN_CACHE_SECONDS=1500
NAV_REQUEST_TIMEOUT=30
